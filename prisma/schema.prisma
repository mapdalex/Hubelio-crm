// Prisma Schema für CRM System
// PostgreSQL Datenbank - selbst-gehostet via Docker/Coolify

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// BENUTZER & AUTHENTIFIZIERUNG
// ============================================

enum Role {
  SUPERADMIN  // System-weiter Superadmin - kann Firmen und deren Admins erstellen
  ADMIN
  MITARBEITER
  KUNDE
  BUCHHALTUNG
  GAST
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          Role      @default(GAST)
  theme         String    @default("system") // light, dark, system
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLogin     DateTime?
  isActive      Boolean   @default(true)

  // Beziehungen
  sessions       Session[]
  tickets        Ticket[]        @relation("TicketCreator")
  assignedTickets Ticket[]       @relation("TicketAssignee")
  ticketComments TicketComment[]
  todos          Todo[]
  files          File[]
  customer       Customer?       @relation("CustomerUser")
  activityLogs   ActivityLog[]
  companyUsers   CompanyUser[]   // Multi-company membership
  
  // Kalender-Beziehungen
  calendars          Calendar[]          @relation("UserCalendars")
  createdEvents      CalendarEvent[]     @relation("UserCreatedEvents")
  sharedCalendars    CalendarShare[]     @relation("SharedCalendars")
  calendarVisibility CalendarVisibility[] @relation("UserCalendarVisibility")
  eventAttendances   EventAttendee[]     @relation("EventAttendances")

  @@index([email])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ============================================
// KUNDEN
// ============================================

model Customer {
  id              String    @id @default(cuid())
  companyId       String?   // Multi-tenant: owning company
  customerNumber  String    @unique
  companyName     String?   // Customer's company name (renamed from company)
  firstName       String
  lastName        String
  email           String?
  phone           String?
  mobile          String?
  street          String?
  zipCode         String?
  city            String?
  country         String?   @default("Deutschland")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isActive        Boolean   @default(true)

  // Beziehung zu User (wenn Kunde Login hat)
  userId          String?   @unique
  user            User?     @relation("CustomerUser", fields: [userId], references: [id])

  // Multi-tenant relation
  ownerCompany    Company?  @relation("CompanyCustomers", fields: [companyId], references: [id])

  // Beziehungen
  contacts        Contact[]
  computers       Computer[]
  domains         Domain[]
  services        Service[]
  tickets         Ticket[]
  files           File[]

  @@index([companyId])
  @@index([customerNumber])
  @@index([companyName])
  @@index([lastName])
  @@index([email])
}

model Contact {
  id          String   @id @default(cuid())
  customerId  String
  firstName   String
  lastName    String
  position    String?
  email       String?
  phone       String?
  mobile      String?
  isPrimary   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ============================================
// COMPUTER / PCs
// ============================================

model Computer {
  id              String    @id @default(cuid())
  customerId      String
  name            String
  type            String?   // Desktop, Laptop, Server, etc.
  manufacturer    String?
  model           String?
  serialNumber    String?
  operatingSystem String?
  processor       String?
  ram             String?
  storage         String?
  ipAddress       String?
  macAddress      String?
  purchaseDate    DateTime?
  warrantyUntil   DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isActive        Boolean   @default(true)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tickets  Ticket[]

  @@index([customerId])
  @@index([name])
}

// ============================================
// VERKAUF - DOMAINS & SERVICES
// ============================================

model Domain {
  id              String    @id @default(cuid())
  customerId      String
  domainName      String
  registrar       String?
  purchaseDate    DateTime?
  expiryDate      DateTime?
  renewalDate     DateTime?
  autoRenew       Boolean   @default(true)
  costPrice       Decimal?  @db.Decimal(10, 2)
  sellPrice       Decimal?  @db.Decimal(10, 2)
  billingCycle    String?   // monthly, yearly, etc.
  status          String    @default("active") // active, expired, transferred
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([domainName])
  @@index([expiryDate])
  @@index([renewalDate])
}

model Service {
  id              String    @id @default(cuid())
  customerId      String
  name            String
  description     String?
  type            String?   // Hosting, Support, Wartung, etc.
  startDate       DateTime?
  endDate         DateTime?
  renewalDate     DateTime?
  billingCycle    String?   // monthly, yearly, etc.
  costPrice       Decimal?  @db.Decimal(10, 2)
  sellPrice       Decimal?  @db.Decimal(10, 2)
  status          String    @default("active") // active, paused, cancelled
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([renewalDate])
  @@index([status])
}

// ============================================
// TICKETS
// ============================================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id            String         @id @default(cuid())
  companyId     String?        // Multi-tenant
  ticketNumber  String         @unique
  subject       String
  description   String
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(MEDIUM)
  
  // Beziehungen
  customerId    String?
  computerId    String?
  createdById   String
  assignedToId  String?
  
  // E-Mail Referenz
  emailMessageId String?
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  closedAt      DateTime?

  ownerCompany  Company?       @relation("CompanyTickets", fields: [companyId], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])
  computer      Computer?      @relation(fields: [computerId], references: [id])
  createdBy     User           @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo    User?          @relation("TicketAssignee", fields: [assignedToId], references: [id])
  comments      TicketComment[]
  attachments   File[]

  @@index([companyId])
  @@index([ticketNumber])
  @@index([status])
  @@index([customerId])
  @@index([assignedToId])
  @@index([createdAt])
}

model TicketComment {
  id          String   @id @default(cuid())
  ticketId    String
  userId      String
  content     String
  isInternal  Boolean  @default(false) // Interne Notiz oder öffentlich
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

// ============================================
// E-MAIL EINSTELLUNGEN
// ============================================

model EmailSettings {
  id            String   @id @default(cuid())
  companyId     String?  // Multi-tenant
  name          String
  protocol      String   // IMAP, POP3
  host          String
  port          Int
  username      String
  password      String   // Encrypted
  useSsl        Boolean  @default(true)
  smtpHost      String?
  smtpPort      Int?
  smtpUsername  String?
  smtpPassword  String?  // Encrypted
  smtpUseSsl    Boolean  @default(true)
  isActive      Boolean  @default(true)
  lastSync      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownerCompany  Company? @relation("CompanyEmailSettings", fields: [companyId], references: [id])

  @@index([companyId])
}

// ============================================
// TODOS
// ============================================

model Todo {
  id          String    @id @default(cuid())
  companyId   String?   // Multi-tenant
  userId      String
  title       String
  description String?
  dueDate     DateTime?
  priority    String    @default("medium") // low, medium, high
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ownerCompany Company? @relation("CompanyTodos", fields: [companyId], references: [id])
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([dueDate])
  @@index([isCompleted])
}

// ============================================
// DATENABLAGE / FILES
// ============================================

model File {
  id           String   @id @default(cuid())
  companyId    String?  // Multi-tenant
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  
  // Optionale Verknüpfungen
  customerId   String?
  ticketId     String?
  uploadedById String
  
  createdAt    DateTime @default(now())

  ownerCompany Company?  @relation("CompanyFiles", fields: [companyId], references: [id])
  customer     Customer? @relation(fields: [customerId], references: [id])
  ticket       Ticket?   @relation(fields: [ticketId], references: [id])
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])

  @@index([companyId])
  @@index([customerId])
  @@index([ticketId])
}

// ============================================
// SYSTEM EINSTELLUNGEN
// ============================================

model SystemSettings {
  id        String @id @default("system")
  companyName String @default("Mein Unternehmen")
  companyLogo String?
  companyAddress String?
  companyPhone String?
  companyEmail String?
  defaultLanguage String @default("de")
  ticketPrefix String @default("TKT")
  customerPrefix String @default("KD")
  updatedAt DateTime @updatedAt
}

// ============================================
// AKTIVITÄTSLOG
// ============================================

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  companyId   String?
  action      String
  entity      String
  entityId    String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([companyId])
  @@index([entity])
  @@index([createdAt])
}

// ============================================
// MULTI-TENANT: COMPANIES & MODULES
// ============================================

model Company {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  logo          String?
  address       String?
  phone         String?
  email         String?
  website       String?
  timezone      String   @default("Europe/Berlin")
  currency      String   @default("EUR")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  companyUsers  CompanyUser[]
  subscriptions Subscription[]
  customers     Customer[]     @relation("CompanyCustomers")
  tickets       Ticket[]       @relation("CompanyTickets")
  files         File[]         @relation("CompanyFiles")
  todos         Todo[]         @relation("CompanyTodos")
  activityLogs  ActivityLog[]
  emailSettings EmailSettings[] @relation("CompanyEmailSettings")
  calendars     Calendar[]     @relation("CompanyCalendars")

  @@index([slug])
  @@index([isActive])
}

enum ModuleId {
  CORE
  MESSAGE
  SALES
  IT
  SOCIALS
  CAMPAIGNS
  ANALYTICS
  FINANCE
  RENT
}

enum ModuleStatus {
  ACTIVE
  BETA
  DEPRECATED
  COMING_SOON
}

model Module {
  id          String       @id @default(cuid())
  moduleId    ModuleId     @unique
  name        String
  description String?
  icon        String?
  features    String[]     // Array of feature flags
  basePrice   Decimal      @db.Decimal(10, 2)
  status      ModuleStatus @default(ACTIVE)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  subscriptions Subscription[]

  @@index([moduleId])
  @@index([status])
}

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  TRIAL
}

model Subscription {
  id          String             @id @default(cuid())
  companyId   String
  moduleId    String
  tier        SubscriptionTier   @default(FREE)
  status      SubscriptionStatus @default(ACTIVE)
  seatLimit   Int?               // null = unlimited
  startDate   DateTime           @default(now())
  endDate     DateTime?
  trialEndsAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  module  Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([companyId, moduleId])
  @@index([companyId])
  @@index([moduleId])
  @@index([status])
}

enum CompanyRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model CompanyUser {
  id        String      @id @default(cuid())
  userId    String
  companyId String
  role      CompanyRole @default(MEMBER)
  isDefault Boolean     @default(false) // Default company for user
  joinedAt  DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Module-specific permissions
  modulePermissions ModulePermission[]

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

model ModulePermission {
  id            String   @id @default(cuid())
  companyUserId String
  moduleId      ModuleId
  canAccess     Boolean  @default(true)
  canEdit       Boolean  @default(false)
  canAdmin      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyUser CompanyUser @relation(fields: [companyUserId], references: [id], onDelete: Cascade)

  @@unique([companyUserId, moduleId])
  @@index([companyUserId])
  @@index([moduleId])
}

// ============================================
// KALENDER
// ============================================

enum CalendarType {
  PERSONAL    // Persoenlicher Kalender des Users
  COMPANY     // Firmenkalender
  VACATION    // Urlaubskalender
  SHARED      // Geteilter Kalender
}

enum CalendarEventType {
  EVENT       // Normales Event
  VACATION    // Urlaubseintrag
  MEETING     // Besprechung
  REMINDER    // Erinnerung
  TASK        // Aufgabe
  BIRTHDAY    // Geburtstag
  HOLIDAY     // Feiertag
}

model Calendar {
  id          String       @id @default(cuid())
  companyId   String?      // Multi-tenant
  ownerId     String?      // User der den Kalender besitzt (null = Firmenkalender)
  name        String
  description String?
  color       String       @default("#3b82f6") // Hex color fuer Events
  type        CalendarType @default(PERSONAL)
  isDefault   Boolean      @default(false)
  isPublic    Boolean      @default(false) // Sichtbar fuer alle Firmenmitglieder
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  ownerCompany Company?          @relation("CompanyCalendars", fields: [companyId], references: [id])
  owner        User?             @relation("UserCalendars", fields: [ownerId], references: [id])
  events       CalendarEvent[]
  shares       CalendarShare[]
  visibility   CalendarVisibility[]

  @@index([companyId])
  @@index([ownerId])
  @@index([type])
}

model CalendarEvent {
  id             String            @id @default(cuid())
  calendarId     String
  title          String
  description    String?
  location       String?
  eventType      CalendarEventType @default(EVENT)
  startDate      DateTime
  endDate        DateTime
  allDay         Boolean           @default(false)
  isRecurring    Boolean           @default(false)
  recurrenceRule String?           // RRULE Format (z.B. "FREQ=WEEKLY;BYDAY=MO,WE,FR")
  color          String?           // Ueberschreibt Kalenderfarbe
  createdById    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // Relations
  calendar  Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  createdBy User     @relation("UserCreatedEvents", fields: [createdById], references: [id])
  attendees EventAttendee[]

  @@index([calendarId])
  @@index([startDate])
  @@index([endDate])
  @@index([createdById])
}

model CalendarShare {
  id         String   @id @default(cuid())
  calendarId String
  userId     String
  canEdit    Boolean  @default(false) // Nur lesen oder auch bearbeiten
  createdAt  DateTime @default(now())

  // Relations
  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  user     User     @relation("SharedCalendars", fields: [userId], references: [id])

  @@unique([calendarId, userId])
  @@index([calendarId])
  @@index([userId])
}

model CalendarVisibility {
  id         String   @id @default(cuid())
  userId     String
  calendarId String
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user     User     @relation("UserCalendarVisibility", fields: [userId], references: [id])
  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@unique([userId, calendarId])
  @@index([userId])
  @@index([calendarId])
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    String   @default("pending") // pending, accepted, declined, tentative
  createdAt DateTime @default(now())

  // Relations
  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation("EventAttendances", fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}
