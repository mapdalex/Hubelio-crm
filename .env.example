# CRM System - Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an

# ============================================
# DATENBANK
# ============================================
DATABASE_URL="postgresql://crm_user:your_secure_password@localhost:5432/crm_database"

# Für Docker/Coolify:
# DATABASE_URL="postgresql://crm_user:your_secure_password@db:5432/crm_database"

# PostgreSQL Einstellungen (für docker-compose)
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=crm_database

# ============================================
# AUTHENTIFIZIERUNG
# ============================================
# Geheimer Schlüssel für Session-Verschlüsselung
# Generiere mit: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-change-in-production"

# URL der Anwendung
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# E-MAIL EINSTELLUNGEN (Optional)
# ============================================
# Diese können auch über die Admin-Oberfläche konfiguriert werden
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password
# SMTP_FROM=noreply@example.com

# IMAP/POP3 für Ticket-System
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USER=support@example.com
# IMAP_PASSWORD=your-imap-password

# ============================================
# DATEI-UPLOADS
# ============================================
# Maximale Dateigröße in Bytes (Standard: 10MB)
MAX_FILE_SIZE=10485760

# Upload-Verzeichnis
UPLOAD_DIR=./uploads
